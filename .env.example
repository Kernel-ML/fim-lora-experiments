# Copy this to .env and fill in values (never commit .env)
# Or set these in ~/.bashrc on SageMaker

HF_TOKEN=hf_your_token_here
HUGGING_FACE_HUB_TOKEN=hf_your_token_here   # same value, some libs use this name

# For SageMaker job launcher (optional — Studio auto-detects these)
SAGEMAKER_ROLE=arn:aws:iam::YOUR_ACCOUNT:role/YourSageMakerRole
SAGEMAKER_BUCKET=your-s3-bucket-name

# For experiment tracking (optional)
WANDB_API_KEY=your_wandb_key
